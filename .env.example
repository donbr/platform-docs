# Platform Docs Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Qdrant Cloud credentials (required)
# =============================================================================
QDRANT_API_URL=https://your-cluster.cloud.qdrant.io:6333
QDRANT_API_KEY=your-qdrant-api-key

# =============================================================================
# OpenAI API key
# Required for: platform-docs server, upload_to_qdrant.py
# Optional for: platform-docs-free server (uses FastEmbed instead)
# =============================================================================
OPENAI_API_KEY=your-openai-api-key
